pkgdesc="GUI for configuring Hyprland!"
url="https://github.com/timasoft/hyprviz"
license=("GPL-2.0")
arch=("x86_64")
provides=("hyprviz")
conflicts=("hyprviz")
depends=("gtk4" "glib2" "desktop-file-utils" "hyprland")
